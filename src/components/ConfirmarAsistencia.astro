<section
    class="relative w-full flex flex-col items-center overflow-hidden pt-10 px-8 pb-0"
>
    <img
        id="conf-flor"
        src="/imagenes/florizquierdo.png"
        alt=""
        class="absolute -right-8 top-0 w-24 sm:w-28 h-auto object-contain pointer-events-none select-none"
        style="transform: scaleX(-1);"
    />

    <div class="w-full flex flex-col items-center text-center gap-4 z-10">
        <img
            id="conf-icon"
            src="/imagenes/calendario.png"
            alt="Confirmar asistencia"
            class="w-14 h-auto object-contain"
            style="filter: brightness(0) saturate(100%) invert(70%) sepia(50%) saturate(500%) hue-rotate(5deg) brightness(95%);"
        />

        <p
            id="conf-titulo"
            class="font-great-vibes text-3xl sm:text-4xl text-[#C9A94B] leading-tight"
        >
            Confirmar asistencia
        </p>

        <p
            id="conf-texto"
            class="font-crimson uppercase text-[#e8a0b0] text-base sm:text-sm tracking-widest leading-relaxed max-w-xs"
        >
            Por favor confirma tu asistencia
        </p>

        <a
            id="conf-btn"
            href="https://wa.link/s0vbuf"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-7 py-2.5 rounded-full font-crimson uppercase tracking-[0.2em] text-sm font-semibold text-white transition-opacity hover:opacity-85"
            style="background: linear-gradient(135deg, #C9A94B, #ddb95a);"
        >
            Confirmar aquí
        </a>

        <div
            id="conf-linea"
            class="flex items-center gap-2 w-full max-w-xs mt-2"
        >
            <div class="flex-1 h-px bg-[#C9A94B] opacity-30"></div>
            <div class="w-1 h-1 rounded-full bg-[#C9A94B] opacity-40"></div>
            <div class="flex-1 h-px bg-[#C9A94B] opacity-30"></div>
        </div>

        <p
            id="conf-final"
            class="font-crimson uppercase text-[#C9A94B] text-base sm:text-sm tracking-widest leading-relaxed max-w-xs"
        >
            Tu presencia y alegría hará que esta noche sea inolvidable.
        </p>

        <div class="relative w-full flex justify-center mt-6">
            <!-- Mariposas lado izquierdo -->
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-10 pointer-events-none"
                style="left: 8%; top: 10%; animation: volarA 7s ease-in-out infinite;"
            />
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-7 pointer-events-none"
                style="left: 14%; top: 45%; animation: volarB 9s ease-in-out infinite 1.5s;"
            />
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-8 pointer-events-none"
                style="left: 4%; top: 70%; animation: volarA 8s ease-in-out infinite 3s;"
            />

            <!-- Mariposas lado derecho -->
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-9 pointer-events-none"
                style="right: 10%; top: 15%; transform: scaleX(-1); animation: volarB 8s ease-in-out infinite 0.5s;"
            />
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-7 pointer-events-none"
                style="right: 5%; top: 55%; transform: scaleX(-1); animation: volarA 9s ease-in-out infinite 2s;"
            />
            <img
                src="/imagenes/mariposa.png"
                alt=""
                class="absolute w-10 pointer-events-none"
                style="right: 15%; top: 75%; transform: scaleX(-1); animation: volarB 7s ease-in-out infinite 4s;"
            />

            <img
                id="conf-per"
                src="/imagenes/per.png"
                alt=""
                class="w-48 sm:w-56 h-auto object-contain block"
                style="transform: translateY(40px);"
            />
        </div>
    </div>

    <!-- Flores pegadas al borde exterior de la sección -->
    <img
        src="/imagenes/flormorada.png"
        alt=""
        class="absolute -left-8 bottom-0 w-20 sm:w-24 h-auto object-contain pointer-events-none select-none"
        style="clip-path: inset(0 0 0 25%);"
    />
    <img
        src="/imagenes/flormorada.png"
        alt=""
        class="absolute -right-8 bottom-0 w-20 sm:w-24 h-auto object-contain pointer-events-none select-none"
        style="transform: scaleX(-1); clip-path: inset(0 0 0 25%);"
    />
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);
    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set("#conf-flor", { opacity: 0, x: 50 });
            gsap.set("#conf-icon", { opacity: 0, scale: 0.8 });
            gsap.set("#conf-titulo", { opacity: 0, y: 20 });
            gsap.set("#conf-texto", { opacity: 0, y: 16 });
            gsap.set("#conf-btn", { opacity: 0, y: 16 });
            gsap.set("#conf-linea", { opacity: 0, scaleX: 0.5 });
            gsap.set("#conf-final", { opacity: 0, y: 16 });
            gsap.set("#conf-per", { opacity: 0, y: 20 });

            ScrollTrigger.create({
                trigger: "#conf-icon",
                start: "top 88%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to("#conf-flor", {
                        opacity: 1,
                        x: 0,
                        duration: 1.3,
                        ease: "power2.out",
                    })
                        .to(
                            "#conf-icon",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 1,
                                ease: "back.out(1.3)",
                            },
                            "<",
                        )
                        .to(
                            "#conf-titulo",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1.1,
                                ease: "power2.out",
                            },
                            "<0.15",
                        )
                        .to(
                            "#conf-texto",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.12",
                        )
                        .to(
                            "#conf-btn",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "back.out(1.2)",
                            },
                            "<0.12",
                        )
                        .to(
                            "#conf-linea",
                            {
                                opacity: 1,
                                scaleX: 1,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.1",
                        )
                        .to(
                            "#conf-final",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.12",
                        )
                        .to(
                            "#conf-per",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1.2,
                                ease: "power2.out",
                            },
                            "<0.15",
                        );
                },
                onLeaveBack: () => {
                    gsap.set("#conf-flor", { opacity: 0, x: 50 });
                    gsap.set("#conf-icon", { opacity: 0, scale: 0.8 });
                    gsap.set(
                        "#conf-titulo, #conf-texto, #conf-btn, #conf-final",
                        { opacity: 0, y: 16 },
                    );
                    gsap.set("#conf-linea", { opacity: 0, scaleX: 0.5 });
                    gsap.set("#conf-per", { opacity: 0, y: 20 });
                },
            });
        });
    }
</script>

<style>
    @keyframes volarA {
        0% {
            transform: translate(0px, 0px) rotate(-4deg);
        }
        25% {
            transform: translate(-8px, -12px) rotate(3deg);
        }
        50% {
            transform: translate(5px, -20px) rotate(-4deg);
        }
        75% {
            transform: translate(-7px, -8px) rotate(4deg);
        }
        100% {
            transform: translate(0px, 0px) rotate(-4deg);
        }
    }
    @keyframes volarB {
        0% {
            transform: scaleX(-1) translate(0px, 0px) rotate(3deg);
        }
        30% {
            transform: scaleX(-1) translate(7px, -16px) rotate(-4deg);
        }
        60% {
            transform: scaleX(-1) translate(-5px, -22px) rotate(5deg);
        }
        80% {
            transform: scaleX(-1) translate(9px, -10px) rotate(-3deg);
        }
        100% {
            transform: scaleX(-1) translate(0px, 0px) rotate(3deg);
        }
    }
</style>
