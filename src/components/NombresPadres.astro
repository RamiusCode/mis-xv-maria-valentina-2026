<section
    class="relative w-full flex items-center justify-center px-4 py-4 overflow-hidden"
>
    <!-- Flor izquierda abajo -->
    <img
        id="np-flor"
        src="/imagenes/florizquierdo.png"
        alt=""
        class="absolute -left-8 bottom-0 w-24 sm:w-24 md:w-28 h-auto object-contain pointer-events-none select-none"
    />

    <!-- Contenido central -->
    <div class="flex flex-col items-center text-center gap-3 z-10 px-4">
        <p id="np-titulo" class="font-crimson uppercase text-[#C9A94B] text-lg sm:text-xl md:text-2xl leading-snug tracking-wide">
            Acompáñame en este día tan especial junto a
        </p>
        <p id="np-padres" class="font-crimson uppercase text-[#e8a0b0] text-lg sm:text-xl md:text-2xl tracking-wide">
            Mis padres:
        </p>
        <p id="np-nombres" class="font-crimson uppercase text-[#e8a0b0] text-xl sm:text-2xl md:text-3xl leading-snug tracking-wide">
            Eric David Serrano Rojas<br />Daniela Diaz Paz
        </p>
        <p id="np-festejar" class="font-crimson uppercase text-[#C9A94B] text-lg sm:text-xl md:text-2xl tracking-wide mt-2">
            A festejar mis
        </p>
        <p id="np-xv" class="font-crimson uppercase text-[#C9A94B] text-4xl sm:text-5xl tracking-widest">
            XV Años
        </p>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {

            gsap.set("#np-flor",     { opacity: 0, x: -55 });
            gsap.set("#np-titulo",   { opacity: 0, y: 20 });
            gsap.set("#np-padres",   { opacity: 0, y: 20 });
            gsap.set("#np-nombres",  { opacity: 0, y: 20 });
            gsap.set("#np-festejar", { opacity: 0, y: 20 });
            gsap.set("#np-xv",       { opacity: 0, scale: 0.88, y: 10 });

            ScrollTrigger.create({
                trigger: "#np-titulo",
                start: "top 88%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to("#np-flor",    { opacity: 1, x: 0, duration: 1.4, ease: "power2.out" })
                      .to("#np-titulo",  { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" }, "<")
                      .to("#np-padres",  { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" }, "<0.12")
                      .to("#np-nombres", { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" }, "<0.12")
                      .to("#np-festejar",{ opacity: 1, y: 0, duration: 1.1, ease: "power2.out" }, "<0.12")
                      .to("#np-xv",      { opacity: 1, scale: 1, y: 0, duration: 1.3, ease: "back.out(1.2)" }, "<0.1");
                },
                onLeaveBack: () => {
                    gsap.set("#np-flor",     { opacity: 0, x: -55 });
                    gsap.set("#np-titulo, #np-padres, #np-nombres, #np-festejar", { opacity: 0, y: 20 });
                    gsap.set("#np-xv",       { opacity: 0, scale: 0.88, y: 10 });
                },
            });
        });
    }
</script>
