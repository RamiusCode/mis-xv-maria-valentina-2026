<section
    class="relative w-full flex flex-col items-center overflow-hidden py-10 px-6"
>
    <img
        id="rec-flor"
        src="/imagenes/flormorada.png"
        alt=""
        class="absolute -right-8 top-0 w-20 sm:w-32 h-auto object-contain pointer-events-none select-none"
        style="transform: scaleX(-1);"
    />
    <img
        id="rec-flor-izq"
        src="/imagenes/flormorada.png"
        alt=""
        class="absolute -left-8 top-0 w-20 sm:w-32 h-auto object-contain pointer-events-none select-none"
    />

    <div class="w-full flex flex-col items-center text-center gap-4 z-10">
        <!-- <img
            id="rec-icon"
            src="/imagenes/brindis.png"
            alt="Recepción"
            class="w-16 h-auto object-contain"
            style="filter: brightness(0) saturate(100%) invert(70%) sepia(50%) saturate(500%) hue-rotate(5deg) brightness(95%);"
        /> -->

        <p
            id="rec-titulo"
            class="font-great-vibes text-3xl sm:text-4xl text-[#C9A94B] leading-tight"
        >
            Recepción Social
        </p>

        <p
            id="rec-hora"
            class="font-crimson text-xl sm:text-2xl text-[#C9A94B] tracking-wide"
        >
            19:00 PM
        </p>

        <div id="rec-dir" class="flex flex-col items-center gap-1">
            <p
                class="font-crimson uppercase text-[#e8a0b0] text-base tracking-widest leading-snug max-w-xs"
            >
                Dirección<br />Calle Dalence 474
            </p>
        </div>

        <a
            id="rec-btn"
            href="https://maps.app.goo.gl/8WSBReZCJaQKDMpT9"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 flex items-center gap-2 px-7 py-2.5 rounded-full font-crimson uppercase tracking-[0.2em] text-sm font-semibold text-white transition-opacity hover:opacity-85"
            style="background: linear-gradient(135deg, #C9A94B, #ddb95a);"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Ver ubicación
        </a>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);
    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set("#rec-flor", { opacity: 0, x: 50 });
            gsap.set("#rec-flor-izq", { opacity: 0, x: -50 });
            gsap.set("#rec-icon", { opacity: 0, scale: 0.8 });
            gsap.set("#rec-titulo", { opacity: 0, y: 20 });
            gsap.set("#rec-hora", { opacity: 0, y: 18 });
            gsap.set("#rec-dir", { opacity: 0, y: 18 });
            gsap.set("#rec-btn", { opacity: 0, y: 16 });

            ScrollTrigger.create({
                trigger: "#rec-icon",
                start: "top 88%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to("#rec-flor", {
                        opacity: 1,
                        x: 0,
                        duration: 1.3,
                        ease: "power2.out",
                    })
                        .to(
                            "#rec-flor-izq",
                            {
                                opacity: 1,
                                x: 0,
                                duration: 1.3,
                                ease: "power2.out",
                            },
                            "<",
                        )
                        .to(
                            "#rec-icon",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 1,
                                ease: "back.out(1.3)",
                            },
                            "<",
                        )
                        .to(
                            "#rec-titulo",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1.1,
                                ease: "power2.out",
                            },
                            "<0.15",
                        )
                        .to(
                            "#rec-hora",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.12",
                        )
                        .to(
                            "#rec-dir",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.12",
                        )
                        .to(
                            "#rec-btn",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<0.12",
                        );
                },
                onLeaveBack: () => {
                    gsap.set("#rec-flor", { opacity: 0, x: 50 });
                    gsap.set("#rec-flor-izq", { opacity: 0, x: -50 });
                    gsap.set("#rec-icon", { opacity: 0, scale: 0.8 });
                    gsap.set("#rec-titulo, #rec-hora, #rec-dir, #rec-btn", {
                        opacity: 0,
                        y: 18,
                    });
                },
            });
        });
    }
</script>
