<section class="w-full flex flex-col justify-center items-center px-6 py-10">
    <img
        id="ded-sep-top"
        src="/imagenes/separa.png"
        alt="Separador decorativo"
        class="w-48 sm:w-56 md:w-64 h-auto object-contain mb-6"
    />
    <p
        id="ded-texto"
        class="font-crimson uppercase text-[#e8a0b0] text-center text-base sm:text-lg md:text-xl leading-relaxed max-w-md tracking-wide"
    >
        Hay momentos inolvidables que se atesoran con el corazón para siempre.
        Por esa razón, con la alegría y emoción, quiero compartir contigo esta
        noche maravillosa celebrando juntos mis XV años.
    </p>
    <img
        id="ded-sep-bot"
        src="/imagenes/separa.png"
        alt="Separador decorativo"
        class="w-48 sm:w-56 md:w-64 h-auto object-contain mt-6"
        style="transform: scaleY(-1);"
    />
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {

            gsap.set("#ded-sep-top", { opacity: 0, y: -15, scaleX: 0.7 });
            gsap.set("#ded-texto",   { opacity: 0, y: 20 });
            gsap.set("#ded-sep-bot", { opacity: 0, y: 15, scaleX: 0.7 });

            ScrollTrigger.create({
                trigger: "#ded-sep-top",
                start: "top 88%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to("#ded-sep-top", { opacity: 1, y: 0, scaleX: 1, duration: 1.2, ease: "power2.out" })
                      .to("#ded-texto",   { opacity: 1, y: 0, duration: 1.3, ease: "power2.out" }, "<0.15")
                      .to("#ded-sep-bot", { opacity: 1, y: 0, scaleX: 1, duration: 1.2, ease: "power2.out" }, "<0.15");
                },
                onLeaveBack: () => {
                    gsap.set("#ded-sep-top", { opacity: 0, y: -15, scaleX: 0.7 });
                    gsap.set("#ded-texto",   { opacity: 0, y: 20 });
                    gsap.set("#ded-sep-bot", { opacity: 0, y: 15, scaleX: 0.7 });
                },
            });
        });
    }
</script>
